DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: disable HTTP self-heal (migrate on missing tenant tables). Default True.
# Production: set TENANT_LAZY_SCHEMA_REPAIR=False and run `python manage.py migrate_schemas` on deploy.
# TENANT_LAZY_SCHEMA_REPAIR=False

# PostgreSQL — fill in before running
DB_NAME=edusaas_db
DB_USER=edusaas_user
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
